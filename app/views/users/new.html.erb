<h1> Users form </h1>

<% if @user.errors.any? %>
  <div style="color: red;">
    <h3>Errors found:</h3>
    <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user, local: true do |form| %>
  <div>
    <%= form.label :first_name, "First name" %>
    <%= form.text_field :first_name, placeholder: "Enter the first name" %>
  </div>

  <div>
    <%= form.label :last_name, "Last name" %>
    <%= form.text_field :last_name, placeholder: "Enter the last name" %>
  </div>

  <div>
    <%= form.label :email, "Email" %>
    <%= form.text_field :email, placeholder: "Enter the email" %>
  </div>

  <div>
    <%= form.submit "Save" %>
  </div>

  <%= link_to 'Back', users_path %>
<% end %>
