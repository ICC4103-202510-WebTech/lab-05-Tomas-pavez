<h1>Users</h1>

<div style="margin-bottom: 20px;">
  <%= link_to 'Chats', chats_path, style: "margin-right: 10px; padding: 8px 12px; background: #ccc; text-decoration: none;" %>
  <%= link_to 'Messages', messages_path, style: "margin-right: 10px; padding: 8px 12px; background: #ccc; text-decoration: none;" %>
  <%= link_to 'New User', new_user_path, style: "padding: 8px 12px; background-color: #28a745; color: white; text-decoration: none; border-radius: 4px;" %>
</div>

<table>
  <thead>
    <tr>
      <th>Users all</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= link_to "User #{user.id}", user_path(user) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
