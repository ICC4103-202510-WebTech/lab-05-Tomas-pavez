<h1><%= @user.first_name %> <%= @user.last_name %></h1>
<p><strong>Email:</strong> <%= @user.email %></p>

<h2>Sent Chats</h2>
<ul>
  <% @sent_chats.each do |chat| %>
    <li>Chat con <%= chat.receiver.first_name %> (ID: <%= chat.id %>)</li>
  <% end %>
</ul>

<h2>Received Chats</h2>
<ul>
  <% @received_chats.each do |chat| %>
    <li>Chat con <%= chat.sender.first_name %> (ID: <%= chat.id %>)</li>
  <% end %>
</ul>

<h2>Send Messages</h2>
<ul>
  <% @messages.each do |message| %>
    <li>En chat ID <%= message.chat_id %>: <%= message.body %></li>
  <% end %>
</ul>

<%= link_to "Edit User", edit_user_path(@user), style: "margin-right: 10px;" %>
<%= link_to "Back", users_path %>
