<h1>Messages</h1>

<div style="margin-bottom: 20px;">
  <%= link_to 'Users', users_path, style: "margin-right: 10px; padding: 8px 12px; background: #ccc; text-decoration: none;" %>
  <%= link_to 'Chats', chats_path, style: "margin-right: 10px; padding: 8px 12px; background: #ccc; text-decoration: none;" %>
  <%= link_to 'New message', new_message_path, style: "padding: 8px 12px; background-color: #28a745; color: white; text-decoration: none; border-radius: 4px;" %>
</div>

<table>
  <thead>
    <tr>
      <th>Message</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @messages.each do |message| %>
      <tr>
        <td><%= link_to "Message #{message.id}", message_path(message) %></td>
        <td><%= link_to "Edit", edit_message_path(message) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
