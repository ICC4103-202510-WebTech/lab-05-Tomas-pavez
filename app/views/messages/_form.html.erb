<h1>Message form</h1>

<% if @message.errors.any? %>
  <div style="color: red; margin-bottom: 15px;">
    <h3>Errors:</h3>
    <ul>
      <% @message.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @message, local: true do |form| %>
  <div>
    <%= form.label :body, "Body" %>
    <%= form.text_field :body, placeholder: "Enter the body message" %>
  </div>

  <div>
    <%= form.label :chat_id, "Chat ID" %>
    <%= form.number_field :chat_id, placeholder: "Enter the chat ID" %>
  </div>

  <div>
    <%= form.label :user_id, "User ID" %>
    <%= form.number_field :user_id, placeholder: "Enter the User ID" %>
  </div>

  <div>
    <%= form.submit @message.new_record? ? "Create Message" : "Update Message" %>
  </div>

  <%= link_to 'Back', messages_path %>
<% end %>
