<h1>Chat form</h1>

<% if @chat.errors.any? %>
  <div style="color: red; margin-bottom: 15px;">
    <h3>Errors:</h3>
    <ul>
      <% @chat.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @chat, local: true do |form| %>
  <div>
    <%= form.label :sender_id, "Sender ID" %>
    <%= form.number_field :sender_id, placeholder: "Enter the sender ID" %>
  </div>

  <div>
    <%= form.label :receiver_id, "Receiver ID" %>
    <%= form.number_field :receiver_id, placeholder: "Enter the receiver ID" %>
  </div>

  <div>
    <%= form.submit @chat.new_record? ? "Create Chat" : "Update Chat" %>
  </div>

  <%= link_to 'Back', chats_path %>
<% end %>
