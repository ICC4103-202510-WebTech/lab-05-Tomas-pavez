<h1>Chats</h1>


<div style="margin-bottom: 20px;">
  <%= link_to 'Users', users_path, style: "margin-right: 10px; padding: 8px 12px; background: #ccc; text-decoration: none;" %>
  <%= link_to 'Messages', messages_path, style: "margin-right: 10px; padding: 8px 12px; background: #ccc; text-decoration: none;" %>
  <%= link_to 'New Chat', new_chat_path, style: "padding: 8px 12px; background-color: #17a2b8; color: white; text-decoration: none; border-radius: 4px;" %>
</div>


<table>
  <tbody>
    <% @chats.each do |chat| %>
      <tr>
        <td><%= link_to "Chat #{chat.id}", chat_path(chat) %></td>
      </tr>
    <% end %>
  </tbody>
</table>






