<h1> Chat form </h1>

<% if @chat.errors.any? %>
  <div style="color: red; margin-bottom: 15px;">
    <h3>Errors:</h3>
    <ul>
      <% @chat.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @chat, local: true do |form| %>
  <div>
    <%= form.label :sender_id, "Sender_id" %>
    <%= form.text_field :sender_id, placeholder: "Enter the sender ID" %>
  </div>

  <div>
    <%= form.label :receiver_id, "Receiver_id" %>
    <%= form.text_field :receiver_id, placeholder: "Enter the receiver ID" %>
  </div>

  <div>
    <%= form.submit "Save" %>
  </div>

  <%= link_to 'Back', chats_path %>
<% end %>
